{{!-- Combat Stats: thresholds + roll button (shared by soldier & opfor-unit sheets) --}}
<div class="haywire-sheet-combat">
  <label>{{localize "HAYWIRE.CombatStats.Label"}}</label>
  <div class="haywire-combat-thresholds">
    <div class="haywire-threshold">
      <span class="haywire-threshold-label">{{localize "HAYWIRE.CombatStats.Easy"}}</span>
      <span class="haywire-threshold-value">
        {{#if isEditable}}
          <input type="number" name="system.combatStats.easy" value="{{combatStats.easy}}" min="1" />
        {{else}}
          {{combatStats.easy}}
        {{/if}}
      </span>
    </div>
    <div class="haywire-threshold">
      <span class="haywire-threshold-label">{{localize "HAYWIRE.CombatStats.Medium"}}</span>
      <span class="haywire-threshold-value">
        {{#if isEditable}}
          <input type="number" name="system.combatStats.medium" value="{{combatStats.medium}}" min="1" />
        {{else}}
          {{combatStats.medium}}
        {{/if}}
      </span>
    </div>
    <div class="haywire-threshold">
      <span class="haywire-threshold-label">{{localize "HAYWIRE.CombatStats.Hard"}}</span>
      <span class="haywire-threshold-value">
        {{#if isEditable}}
          <input type="number" name="system.combatStats.hard" value="{{combatStats.hard}}" min="1" />
        {{else}}
          {{combatStats.hard}}
        {{/if}}
      </span>
    </div>
  </div>
  <button type="button" class="haywire-roll-btn" data-action="rollD20">
    <i class="fas fa-dice-d20"></i>
    {{localize "HAYWIRE.RollD20"}}
  </button>
</div>
